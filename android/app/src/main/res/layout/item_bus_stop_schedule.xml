<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="8dp"
    android:gravity="center_vertical"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <View
        android:id="@+id/vDot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="12dp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStopName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bekat nomi"
            android:textSize="15sp"
            android:textColor="@color/text_primary" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvArrivalTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="06:30"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginEnd="8dp" />

    <ImageButton
        android:id="@+id/btnRemind"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_bell"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        android:tint="@color/nav_inactive"
        android:contentDescription="Eslatma qo'yish" />

    <ImageButton
        android:id="@+id/btnAutoPay"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_auto_pay"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="centerInside"
        android:tint="@color/nav_inactive"
        android:contentDescription="Avtomatik to'lov" />

</LinearLayout>
